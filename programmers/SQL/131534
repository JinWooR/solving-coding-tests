# https://school.programmers.co.kr/learn/courses/30/lessons/131534
WITH JOINED_USER AS (
    SELECT USER_ID
    FROM USER_INFO
    WHERE '2021-01-01' <= JOINED AND JOINED < '2022-01-01'
)
SELECT
    YEAR(S.SALES_DATE) AS YEAR,
    MONTH(S.SALES_DATE) AS MONTH,
    COUNT(DISTINCT S.USER_ID) AS PURCHASED_USERS,
    ROUND(COUNT(DISTINCT S.USER_ID) / UC.ALL_USERS, 1) AS PUCHASED_RATIO
FROM JOINED_USER U
JOIN ONLINE_SALE S
ON S.USER_ID = U.USER_ID
JOIN (SELECT COUNT(USER_ID) AS ALL_USERS FROM JOINED_USER) UC
GROUP BY YEAR, MONTH
ORDER BY YEAR, MONTH
