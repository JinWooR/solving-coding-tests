# Ver1) CASE WHEN 미사용
SELECT A.HISTORY_ID, FLOOR(A.DAILY_FEE * A.RENTAL_DAYS * (100 - MAX(IFNULL(P.DISCOUNT_RATE, 0))) / 100) AS FEE
FROM CAR_RENTAL_COMPANY_DISCOUNT_PLAN P
RIGHT JOIN (
    SELECT H.HISTORY_ID, C.CAR_ID, C.CAR_TYPE, C.DAILY_FEE, DATEDIFF(END_DATE, START_DATE) + 1 AS RENTAL_DAYS
    FROM CAR_RENTAL_COMPANY_RENTAL_HISTORY H
    JOIN CAR_RENTAL_COMPANY_CAR C
        ON C.CAR_TYPE = '트럭' AND C.CAR_ID = H.CAR_ID
) A
ON P.CAR_TYPE = A.CAR_TYPE
    AND A.RENTAL_DAYS >= REPLACE(P.DURATION_TYPE, '일 이상', '')
GROUP BY H.HISTORY_ID
ORDER BY FEE DESC, H.HISTORY_ID DESC;

# Ver2) CASE WHEN 사용
SELECT A.HISTORY_ID, FLOOR(A.DAILY_FEE * A.RENTAL_DAYS * (100 - IFNULL(P.DISCOUNT_RATE, 0)) / 100) AS FEE
FROM CAR_RENTAL_COMPANY_DISCOUNT_PLAN P
RIGHT JOIN (
    SELECT H.HISTORY_ID, C.CAR_ID, C.CAR_TYPE, C.DAILY_FEE, DATEDIFF(END_DATE, START_DATE) + 1 AS RENTAL_DAYS
    FROM CAR_RENTAL_COMPANY_RENTAL_HISTORY H
    JOIN CAR_RENTAL_COMPANY_CAR C
        ON C.CAR_TYPE = '트럭' AND C.CAR_ID = H.CAR_ID
) A
ON P.CAR_TYPE = A.CAR_TYPE
    AND P.DURATION_TYPE = CASE
        WHEN A.RENTAL_DAYS >= 90 THEN '90일 이상'
        WHEN A.RENTAL_DAYS >= 30 THEN '30일 이상'
        WHEN A.RENTAL_DAYS >= 7 THEN '7일 이상' END
ORDER BY FEE DESC, H.HISTORY_ID DESC;
