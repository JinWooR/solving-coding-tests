# https://school.programmers.co.kr/learn/courses/30/lessons/301651
WITH RECURSIVE GEN(ID, GEN) AS (
    SELECT ID, 1 AS GEN
    FROM ECOLI_DATA
    WHERE PARENT_ID IS NULL
    UNION ALL
    SELECT E.ID, G.GEN + 1
    FROM ECOLI_DATA E
    JOIN GEN G
    ON E.PARENT_ID = G.ID
)
SELECT COUNT(G.ID), G.GEN AS GENERATION
FROM GEN G
LEFT JOIN ECOLI_DATA E
ON G.ID = E.PARENT_ID
WHERE E.ID IS NULL
GROUP BY G.GEN
ORDER BY G.GEN
