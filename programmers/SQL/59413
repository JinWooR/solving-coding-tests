# https://school.programmers.co.kr/learn/courses/30/lessons/59413

WITH RECURSIVE HOURS AS (
    SELECT 0 AS HOUR
    UNION ALL
    SELECT HOUR + 1 AS HOUR
    FROM HOURS
    WHERE HOURS.HOUR < 23
)
SELECT
    H.HOUR,
    IFNULL(A.COUNT, 0) AS COUNT
FROM HOURS H
LEFT JOIN (
    SELECT
        HOUR(DATETIME) AS HOUR,
        COUNT(ANIMAL_ID) AS COUNT
    FROM ANIMAL_OUTS
    GROUP BY HOUR(DATETIME)
) A
ON A.HOUR = H.HOUR
ORDER BY H.HOUR
