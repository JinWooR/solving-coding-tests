/* 비트 연산자를 이용해 각 검색 조건에 맞는 결과 값 출력 */

WITH FRONT AS (
    SELECT SUM(CODE) AS CODE FROM SKILLCODES WHERE CATEGORY = 'Front End'
),
PYTHON AS (
    SELECT CODE FROM SKILLCODES WHERE NAME = 'Python'
),
C_SHARP AS (
    SELECT CODE FROM SKILLCODES WHERE NAME = 'C#'
)
SELECT
    CASE
        WHEN SKILL_CODE & FRONT.CODE AND SKILL_CODE & PYTHON.CODE THEN 'A'
        WHEN SKILL_CODE & C_SHARP.CODE THEN 'B'
        WHEN SKILL_CODE & FRONT.CODE AND SKILL_CODE THEN 'C'
    END AS GRADE,
    ID, EMAIL
FROM DEVELOPERS
JOIN FRONT JOIN PYTHON JOIN C_SHARP
HAVING GRADE IS NOT NULL
ORDER BY GRADE, ID;
