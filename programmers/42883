/*
  직접 해결
*/
import java.util.*;

class Solution {
    public String solution(String number, int k) {
        int len = number.length();
        int[] numbers = Arrays.stream(number.split(""))
            .mapToInt(Integer::parseInt)
            .toArray();
        
        int rightPadding = 0, leftPadding = len - k;
        String answer = "";
        while (answer.length() < (len - k)) {
            int max = 0, cur = 0;
            for (int i = len - leftPadding; i >= rightPadding; i--) {
                int num = numbers[i];
                if (max <= num) {
                    max = num;
                    cur = i;
                }
            }
            answer += max;
            rightPadding = cur + 1;
            leftPadding--;
        }
        
        return answer;
    }
}

/*
  다른 사람의 소스 참고 후 리팩토링

  스택 형식으로 숫자를 생성하며, 주어진 조건(k)안에서 가장 높은 숫자를 최대한 앞에 배치하는 전략.
  1회 반복문 처리를 통해 주어진 요구사항에 맞는 결과값을 반환 가능.
*/
import java.util.*;

class Solution {
    public String solution(String number, int k) {
        int len = number.length() - k;
        Stack<Character> s = new Stack();
        
        for (char c: number.toCharArray()) {
            while (!s.isEmpty() && s.peek() < c && k-- > 0) {
                s.pop();
            }
            s.push(c);
        }
        
        StringBuilder sb = new StringBuilder();
        for (int i = 0; i < len; i++) {
            sb.append(s.get(i));
        }
        
        return sb.toString();
    }
}
